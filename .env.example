# SMTP (RSVP email delivery)
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
RSVP_EMAIL=email-to-receive-rsvps@example.com

# Sentry (error monitoring)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.de.sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=sntrys_your-auth-token-here

# PostHog (analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_your-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
